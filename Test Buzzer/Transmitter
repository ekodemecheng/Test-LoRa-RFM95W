/*
=================================================
 LoRa RFM95W Transmitter
 ESP32 Wemos D1 Mini
 Push Button -> Kirim Data LoRa
=================================================
*/

#include <SPI.h>
#include <LoRa.h>

// -------------------------
// Pin LoRa RFM95W
// -------------------------
#define LORA_SCK   18
#define LORA_MISO  19
#define LORA_MOSI  23
#define LORA_SS    5
#define LORA_RST   14
#define LORA_DIO0  26

// Push Button
#define BUTTON_PIN 4

// Frekuensi LoRa Indonesia
#define BAND 923E6

bool lastButtonState = HIGH;
unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 50;

void setup()
{
  Serial.begin(115200);

  pinMode(BUTTON_PIN, INPUT_PULLUP);

  Serial.println();
  Serial.println("================================");
  Serial.println(" LoRa RFM95W TRANSMITTER");
  Serial.println("================================");

  // SPI LoRa
  SPI.begin(LORA_SCK, LORA_MISO, LORA_MOSI, LORA_SS);

  // Set pin LoRa
  LoRa.setPins(LORA_SS, LORA_RST, LORA_DIO0);

  Serial.println("Initializing LoRa...");

  if (!LoRa.begin(BAND))
  {
    Serial.println("LoRa initialization FAILED!");
    while (1);
  }

  LoRa.setTxPower(20);
  LoRa.enableCrc();

  Serial.println("LoRa Ready");
  Serial.println("Press Button to Send");
}

void loop()
{
  bool reading = digitalRead(BUTTON_PIN);

  if (reading != lastButtonState)
  {
    lastDebounceTime = millis();
  }

  if ((millis() - lastDebounceTime) > debounceDelay)
  {
    // Tombol ditekan (LOW karena pullup)
    if (reading == LOW && lastButtonState == HIGH)
    {
      sendMessage("BUTTON_PRESSED");
    }
  }

  lastButtonState = reading;
}

void sendMessage(String message)
{
  Serial.print("Sending: ");
  Serial.println(message);

  LoRa.beginPacket();
  LoRa.print(message);
  LoRa.endPacket();

  Serial.println("Message Sent");
}
